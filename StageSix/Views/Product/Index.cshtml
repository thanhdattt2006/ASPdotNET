@model IEnumerable<Product>

<link href="~/bootstrap/css/bootstrap.min.css" rel="stylesheet" />

<h1>Day la action Index cua ProductController</h1>
<div class="container">
	<h2>danh sach san pham</h2>
	<div class="table-responsive">
		<table class="table table-hover table-bordered table-striped">
			<thead class="table-dark">
				<tr>
					<th>id</th>
					<th>name</th>
					<th>photo</th>
					
					<th>details</th>
				</tr>
			</thead>
			<tbody>
				@foreach(var item in Model)
				{
					<tr>
						<td>@item.Id</td>
						<td>@item.Name</td>
						<td><img src="~/images/@item.Photo" alt="@item.Name" width="100" /></td>
						
						<td><a asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Xem chi tiet</a></td>
					</tr>
				}
)
			</tbody>
		</table>
	</div>
</div>
<a asp-controller="Home" asp-action="Index">Di ve HomeController</a>