@* @model Product *@
@model ProductViewModel

<link href="~/flatpickr/flatpickr.min.css" rel="stylesheet" />
<script defer src="~/flatpickr/flatpickr.min.js"></script>
<script defer src="~/flatpickr/l10n/vn.min.js"></script>
<script defer src="~/js/init-flatpickr.js"></script>

<h1>Day la action Index cua FormController</h1>
<hr />
@* dung html thuan tuy *@
<form action="/form/show-name">
	<fieldset style="width:fit-content">
		<legend>1) Form tu html thuan:</legend>
		<label for="fullname">Fullname: </label>
		<input type="text" name="fullname" id="name"/>
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* dung tag helper *@
<form asp-controller="Form" asp-action="ShowName" method="get">
	<fieldset style="width:fit-content">
		<legend>2) Form tu tag helper:</legend>
		<label for="fullname">Fullname: </label>
		<input type="text" name="fullname" id="name" />
		<button type="submit">Submit</button>
	</fieldset>
</form>

<form asp-controller="Form" asp-action="ShowNameAndQuantity" method="get">
	<fieldset style="width:fit-content">
		<legend>3) Form tu tag helper dung ViewBag co nhieu tham so:</legend>
		<label for="fullname">Fullname: </label>
		<input type="text" name="fullname" id="name" />
		<label for="quantity">Quantity: </label>
		<input type="text" name="quantity" id="quantity" />
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* dung tag helper Request.Query
chi dung khi method la get
va khi dung thi action k can truyen tham so ma tu boc tach tu query string tren address vao
*@
<form asp-controller="Form" asp-action="ShowNameAndQuantityByRequestQuery" method="get">
	<fieldset style="width:fit-content">
		<legend>4) Form tu tag helper dung Request.Query co nhieu tham so:</legend>
		<label for="fullname">Fullname: </label>
		<input type="text" name="fullname" id="name" />
		<label for="quantity">Quantity: </label>
		<input type="text" name="quantity" id="quantity" />
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* dung tag helper Request.Form
chi dung khi method la post
va khi dung thi action k can truyen tham so ma tu boc tach trong body cua request vao
*@
<form asp-controller="Form" asp-action="ShowNameAndQuantityByRequestForm" method="post">
	<fieldset style="width:fit-content">
		<legend>5) Form tu tag helper dung Request.Form co nhieu tham so:</legend>
		<label for="fullname">Fullname: </label>
		<input type="text" name="fullname" id="name" />
		<label for="quantity">Quantity: </label>
		<input type="text" name="quantity" id="quantity" />
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* dung model
theo dang model binding thi ten cua input phai trung voi ten cua property trong model
dung asp-for de tu dong tao name va id cho input trung voi property trong model
*@
<form asp-controller="Form" asp-action="ShowProduct" method="post">
	<fieldset style="width:fit-content">
		<legend>6) Form tu tag helper dung Model la Product:</legend>
		<label asp-for="Name">Fullname: </label>
		<input asp-for="Name" />
		<label asp-for="Quantity">Quantity: </label>
		<input asp-for="Quantity"/>
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* dung ViewModel
dung thuoc tinh it hon model chi dung cho view
*@
<form asp-controller="Form" asp-action="ShowProductVM" method="post">
	<fieldset style="width:fit-content">
		<legend>7) Form tu tag helper dung ViewModel:</legend>
		<label asp-for="Name">Fullname: </label>
		<input asp-for="Name" />
		@* <label asp-for="SanPham.Name">Fullname: </label>
		<input asp-for="SanPham.Name" /> *@
		<label asp-for="Quantity">Quantity: </label>
		<input asp-for="Quantity" />
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* doi khi thuoc tinh name trung ten *@
<form asp-controller="Form" asp-action="ShowHobbies" method="post">
	<fieldset style="width:fit-content">
		<legend>8) Form tu tag helper trung thuoc tinh Name:</legend>
		<input type="checkbox" name="hobbies" value="reading" /> Reading
		<input type="checkbox" name="hobbies" value="traveling" /> Traveling
		<input type="checkbox" name="hobbies" value="cooking" /> Cooking
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* doi khi thuoc tinh name trung ten, dung for de tao *@
<form asp-controller="Form" asp-action="ShowEmails" method="post">
	<fieldset style="width:fit-content">
		<legend>9) Form tu tag helper trung thuoc tinh Name, dung for de tao:</legend>
		@for(int i = 0; i < 5 ; i++)
		{
			<div>
				email: <input type="text" name="emails" />
			</div>
		}
		<button type="submit">Submit</button>
	</fieldset>
</form>

@* dung Date *@
<form asp-controller="Form" asp-action="ShowDate" method="post">
	<fieldset style="width:fit-content">
		<legend>10) Form tu tag helper dung Date:</legend>
		<label for="dob">Birthday:</label>
		<input type="text" name="dob" id="dob" />
		<button type="submit">Submit</button>
	</fieldset>
</form>