@model Product
<tr>
    <td>@Model.Id</td>
    <td>@Model.Name</td>
    <td>
        <img src="~/images/@Model.Photo" alt="@Model.Name" width="50" />
    </td>
    <td>@Model.StatusDisplay</td>
    <td>
        <a asp-controller="Product" asp-action="Details"
           asp-route-id="@Model.Id">Details</a> |
        <a asp-controller="Product" asp-action="Edit"
           asp-route-id="@Model.Id">Edit</a> |
        <a asp-controller="Product" asp-action="Delete"
           asp-route-id="@Model.Id">Delete</a>
    </td>
</tr>