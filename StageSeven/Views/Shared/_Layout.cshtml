<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="~/bootstrap/css/bootstrap.min.css"/>
    <title>@ViewBag.Title</title>
</head>
<body>
    <div class="container">
        <div class="row">
			<partial name="Partials/_Header" />
        </div>

        <div class="row">
            <partial name="Partials/_Sidebar" />
            <div class="col-md-9">
			    @RenderBody()
		    </div>
